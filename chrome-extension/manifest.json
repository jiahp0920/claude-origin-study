{
  "manifest_version": 3,
  "name": "Claude Code 源码分析",
  "version": "1.0.0",
  "description": "一键访问 Claude Code CLI 源码深度分析文档（侧边栏常驻）",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["sidePanel", "tabs"],
  "background": {
    "service_worker": "background.js"
  }
}
